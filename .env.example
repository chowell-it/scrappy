# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# Comma-separated channel IDs to watch. Leave blank to watch every channel.
# Enable Developer Mode in Discord, right-click a channel > Copy Channel ID.
WATCH_CHANNELS=

# Upload limit (MB) for your server's boost tier. Free tier = 10, boost L2 = 50, L3 = 100.
DISCORD_MAX_MB=10

# Skip videos longer than this many minutes (they download huge and rarely fit).
MAX_MINUTES=30

# Auto-update yt-dlp on startup so site changes don't break downloads. 1=on, 0=off.
# Throttled to once/day. Leave on for a VPS (self-heals on restart); 0 for offline/dev.
AUTO_UPDATE=1
